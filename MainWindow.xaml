<Window x:Class="GameTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:GameTracker.Converters"
        Title="LazerGuanas Game Hunter" Height="700" Width="1100"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Icon="iguana-eye.ico"
        Background="{StaticResource ScaleBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:RatingToStarsConverter x:Key="StarsConverter"/>
        <converters:StaleToColorConverter x:Key="StaleColorConverter"/>
        <converters:RatingToVisibilityConverter x:Key="RatingVisConverter"/>
        <converters:ZeroRatingToVisibilityConverter x:Key="ZeroRatingVisConverter"/>
        <converters:NonEmptyToVisibilityConverter x:Key="NonEmptyVisConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolVisConverter"/>

        <Style x:Key="AddButton" TargetType="Button">
            <Setter Property="Background" Value="#4a7c3a"/>
            <Setter Property="Foreground" Value="#0a1410"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#7cc44a" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7cc44a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColumnHeader" TargetType="Border">
            <Setter Property="CornerRadius" Value="6,6,0,0"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style x:Key="GameCard" TargetType="Border">
            <Setter Property="Background" Value="#1c2a1e"/>
            <Setter Property="BorderBrush" Value="#2e4a30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="#142016"/>
            <Setter Property="Foreground" Value="#c4d4a8"/>
            <Setter Property="BorderBrush" Value="#2e4a30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#7cc44a"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#7cc44a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="GameCardTemplate">
            <Border Style="{StaticResource GameCard}"
                    MouseLeftButtonUp="GameCard_Click"
                    PreviewMouseLeftButtonDown="GameCard_PreviewMouseDown"
                    PreviewMouseMove="GameCard_PreviewMouseMove"
                    Tag="{Binding Id}">
                <Border.ContextMenu>
                    <ContextMenu Background="#142016" BorderBrush="#4a7c3a" BorderThickness="1"
                                 Foreground="#c4d4a8">
                        <MenuItem Header="Move to DORMANT" Click="MoveToDormant_Click"
                                  Foreground="Black"/>
                        <MenuItem Header="Move to HUNTING" Click="MoveToHunting_Click"
                                  Foreground="Black"/>
                        <MenuItem Header="Move to DEVOURED" Click="MoveToDevoured_Click"
                                  Foreground="Black"/>
                        <Separator/>
                        <MenuItem Header="Shed" Click="RemoveGame_Click"
                                  Foreground="Black" FontWeight="Bold"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{x:Static SystemCommands.CloseWindowCommand}"/>
                </Border.InputBindings>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title Row -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Title}"
                                   Foreground="#e8e0c4" FontSize="14" FontWeight="SemiBold"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" CornerRadius="10" Padding="7,2"
                                Background="#3a2a10" Margin="6,0,0,0"
                                BorderBrush="#d4a437" BorderThickness="1"
                                Visibility="{Binding Rating, Converter={StaticResource RatingVisConverter}}">
                            <TextBlock Foreground="#d4a437" FontSize="11" FontWeight="Bold"
                                       Text="{Binding Rating, StringFormat={}{0}/10}"/>
                        </Border>
                    </Grid>

                    <!-- Platform + Genre + Requester -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                        <Border CornerRadius="3" Padding="6,2" Background="#0a1410"
                                BorderBrush="#2e4a30" BorderThickness="1"
                                Visibility="{Binding Platform, Converter={StaticResource NonEmptyVisConverter}}"
                                Margin="0,0,4,0">
                            <TextBlock Text="{Binding Platform}" Foreground="#7a9070" FontSize="11"/>
                        </Border>
                        <Border CornerRadius="3" Padding="6,2" Background="#0a1410"
                                BorderBrush="#2e4a30" BorderThickness="1"
                                Visibility="{Binding Genre, Converter={StaticResource NonEmptyVisConverter}}"
                                Margin="0,0,4,0">
                            <TextBlock Text="{Binding Genre}" Foreground="#7a9070" FontSize="11"/>
                        </Border>
                        <Border CornerRadius="3" Padding="6,2" Background="#1a1408"
                                BorderBrush="#5a3a1a" BorderThickness="1"
                                Visibility="{Binding Requester, Converter={StaticResource NonEmptyVisConverter}}"
                                Margin="0,0,0,0">
                            <TextBlock Foreground="#d4a437" FontSize="11"
                                       Text="{Binding Requester, StringFormat=@{0}}"/>
                        </Border>
                    </StackPanel>

                    <!-- Last Played + Pop-out + Start/Stop -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="7" Height="7"
                                 Fill="{Binding IsStale, Converter={StaticResource StaleColorConverter}}"
                                 VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastPlayedDisplay}"
                                   Foreground="#506050" FontSize="11" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="&#10696;"
                                Tag="{Binding Id}"
                                Click="PopOutSession_Click"
                                ToolTip="Pop out session"
                                Visibility="{Binding IsSessionActive, Converter={StaticResource BoolVisConverter}}"
                                Background="#243a26" Foreground="#7cc44a"
                                BorderThickness="0" Padding="8,3" FontSize="12" Cursor="Hand"
                                Margin="0,0,5,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                            Padding="{TemplateBinding Padding}"
                                            BorderBrush="#4a7c3a" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4a7c3a"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Grid.Column="3" Content="{Binding PlayButtonLabel}"
                                Tag="{Binding Id}"
                                Click="ToggleSession_Click"
                                BorderThickness="0" Padding="9,3" FontSize="11" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#243a26"/>
                                    <Setter Property="Foreground" Value="#7cc44a"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSessionActive}" Value="True">
                                            <Setter Property="Background" Value="#5a1a14"/>
                                            <Setter Property="Foreground" Value="#e89080"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                            Padding="{TemplateBinding Padding}"
                                            BorderBrush="#4a7c3a" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Total play time -->
                    <Grid Grid.Row="3" Margin="0,6,0,0"
                          Visibility="{Binding HasPlayTime, Converter={StaticResource BoolVisConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#9201;" Foreground="#7cc44a" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                   Foreground="#a8c488" FontSize="11"
                                   Text="{Binding TotalPlayTimeDisplay, StringFormat='{}{0} played'}"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border BorderBrush="#4a7c3a" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#0a1410"
                BorderBrush="#2e4a30" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Source="/iguana-eye.ico" Width="18" Height="18"
                           Margin="0,0,8,0" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="LAZERGUANAS GAME HUNTER"
                               Foreground="#7cc44a" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#x21BB;" Click="CheckUpdates_Click"
                            Style="{StaticResource WindowControlButton}"
                            ToolTip="Check for updates"/>
                    <Button Content="&#x2013;" Click="Minimize_Click"
                            Style="{StaticResource WindowControlButton}"/>
                    <Button x:Name="MaxRestoreButton" Content="&#x25A1;" Click="MaxRestore_Click"
                            Style="{StaticResource WindowControlButton}"/>
                    <Button Content="&#x2715;" Click="Close_Click"
                            Style="{StaticResource WindowCloseButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Top Bar -->
        <Border Grid.Row="1" Background="#0a1410" Padding="20,14"
                BorderBrush="#4a7c3a" BorderThickness="0,0,0,2"
                shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/iguana-eye.ico" Width="28" Height="28"
                           Margin="0,0,12,0" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="LazerGuanas Game Hunter"
                               Foreground="#e8e0c4" FontSize="20" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBox x:Name="SearchBox" Grid.Column="1"
                         Style="{StaticResource SearchBox}"
                         Width="220" Height="36"
                         TextChanged="SearchBox_TextChanged">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <Button Grid.Column="3" Content="+ Add Game"
                        Style="{StaticResource AddButton}"
                        Height="36"
                        Click="AddGame_Click"/>
            </Grid>
        </Border>

        <!-- Search placeholder -->
        <Border Grid.Row="2" Padding="20,0,20,0" Height="0"
                x:Name="SearchPlaceholderHint"/>

        <!-- Kanban Columns -->
        <Grid Grid.Row="3" Margin="16,16,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Not Started Column (cool slate-moss) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#1a2620" CornerRadius="8,8,0,0" Padding="14,10"
                        BorderBrush="#3a5a44" BorderThickness="1,1,1,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DORMANT" Foreground="#7a9a8a"
                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="#2a4a3a" CornerRadius="10" Padding="8,2">
                            <TextBlock x:Name="NotStartedCount" Text="0"
                                       Foreground="#a0e0c0" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Background="#0f1812" CornerRadius="0,0,8,8"
                        BorderBrush="#2e4a30" BorderThickness="1,0,1,1"
                        AllowDrop="True" Tag="NotStarted"
                        DragOver="Column_DragOver" DragLeave="Column_DragLeave"
                        Drop="Column_Drop">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                        <ItemsControl x:Name="NotStartedList" ItemTemplate="{StaticResource GameCardTemplate}"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- In Progress Column (lizard green) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#1e3a1e" CornerRadius="8,8,0,0" Padding="14,10"
                        BorderBrush="#4a7c3a" BorderThickness="1,1,1,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="HUNTING" Foreground="#7cc44a"
                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="#3a5a2a" CornerRadius="10" Padding="8,2">
                            <TextBlock x:Name="InProgressCount" Text="0"
                                       Foreground="#c4e090" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Background="#0f1810" CornerRadius="0,0,8,8"
                        BorderBrush="#4a7c3a" BorderThickness="1,0,1,1"
                        AllowDrop="True" Tag="InProgress"
                        DragOver="Column_DragOver" DragLeave="Column_DragLeave"
                        Drop="Column_Drop">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                        <ItemsControl x:Name="InProgressList" ItemTemplate="{StaticResource GameCardTemplate}"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Beaten Column (amber / reptile eye) -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#3a2a10" CornerRadius="8,8,0,0" Padding="14,10"
                        BorderBrush="#d4a437" BorderThickness="1,1,1,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DEVOURED" Foreground="#d4a437"
                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="#5a3a1a" CornerRadius="10" Padding="8,2">
                            <TextBlock x:Name="BeatenCount" Text="0"
                                       Foreground="#e8c870" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Background="#1a1408" CornerRadius="0,0,8,8"
                        BorderBrush="#5a3a1a" BorderThickness="1,0,1,1"
                        AllowDrop="True" Tag="Beaten"
                        DragOver="Column_DragOver" DragLeave="Column_DragLeave"
                        Drop="Column_Drop">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                        <ItemsControl x:Name="BeatenList" ItemTemplate="{StaticResource GameCardTemplate}"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="#0a1410" Padding="20,8" Margin="0,8,0,0"
                BorderBrush="#2e4a30" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Foreground="#7a9070" FontSize="11"/>
        </Border>
    </Grid>
    </Border>
</Window>
