<Window x:Class="GameTracker.Views.GameInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:GameTracker.Converters"
        Title="Game Info"
        Width="760" Height="580"
        MinWidth="600" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Icon="/iguana-eye.ico"
        Background="{StaticResource ScaleBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:NonEmptyToVisibilityConverter x:Key="NonEmptyVisConverter"/>
        <converters:MarkerOffsetConverter x:Key="MarkerOffsetConverter"/>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7cc44a"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#4a7c3a" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#0a1410"
                    BorderBrush="#2e4a30" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Image Source="/iguana-eye.ico" Width="16" Height="16" Margin="0,0,8,0"
                               VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="GAME INFO" Foreground="#7cc44a"
                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="&#x2715;" Click="Close_Click"
                            Style="{StaticResource WindowCloseButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,16,20,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: info -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="TitleText" Foreground="#e8e0c4" FontSize="22"
                                   FontWeight="Bold" TextWrapping="Wrap"/>

                        <Border x:Name="StatusBadge" CornerRadius="10" Padding="10,3"
                                HorizontalAlignment="Left" Margin="0,8,0,0">
                            <TextBlock x:Name="StatusText" FontSize="11" FontWeight="Bold"/>
                        </Border>

                        <StackPanel x:Name="ChipPanel" Orientation="Horizontal" Margin="0,10,0,0">
                            <Border x:Name="PlatformChip" CornerRadius="3" Padding="7,2" Background="#0a1410"
                                    BorderBrush="#2e4a30" BorderThickness="1" Margin="0,0,5,0">
                                <TextBlock x:Name="PlatformText" Foreground="#7a9070" FontSize="11"/>
                            </Border>
                            <Border x:Name="GenreChip" CornerRadius="3" Padding="7,2" Background="#0a1410"
                                    BorderBrush="#2e4a30" BorderThickness="1" Margin="0,0,5,0">
                                <TextBlock x:Name="GenreText" Foreground="#7a9070" FontSize="11"/>
                            </Border>
                            <Border x:Name="RequesterChip" CornerRadius="3" Padding="7,2" Background="#1a1408"
                                    BorderBrush="#5a3a1a" BorderThickness="1">
                                <TextBlock x:Name="RequesterText" Foreground="#d4a437" FontSize="11"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="RATING" Style="{StaticResource Label}"/>
                        <TextBlock x:Name="RatingText" Foreground="#d4a437" FontSize="14"/>

                        <TextBlock Text="TIME PLAYED" Style="{StaticResource Label}"/>
                        <TextBlock x:Name="TotalText" Foreground="#a8c488" FontSize="14"/>
                        <TextBlock x:Name="LastPlayedText" Foreground="#7a9070" FontSize="12" Margin="0,2,0,0"/>
                        <TextBlock x:Name="DateAddedText" Foreground="#506050" FontSize="12" Margin="0,2,0,0"/>

                        <TextBlock Text="NOTES" Style="{StaticResource Label}"/>
                        <Border Background="#142016" BorderBrush="#2e4a30" BorderThickness="1"
                                CornerRadius="4" Padding="8,6">
                            <TextBlock x:Name="NotesText" Foreground="#c4d4a8" FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Right: sessions -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="PLAY SESSIONS" Foreground="#7cc44a" FontSize="11"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" CornerRadius="10" Padding="9,2"
                                Background="#1e3a1e" BorderBrush="#4a7c3a" BorderThickness="1">
                            <TextBlock x:Name="TotalTimeBadge" Foreground="#c4e090" FontSize="11"
                                       FontWeight="Bold"/>
                        </Border>
                    </Grid>
                    <Border Grid.Row="1" Background="#142016" BorderBrush="#2e4a30" BorderThickness="1"
                            CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock x:Name="NoSessionsText" Text="No sessions logged yet"
                                           Foreground="#506050" FontSize="12" Margin="10,12"/>
                                <ItemsControl x:Name="SessionsItems">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#1e2a20" BorderThickness="0,0,0,1" Padding="10,8">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding StartDisplay}"
                                                                   Foreground="#c4d4a8" FontSize="12"
                                                                   VerticalAlignment="Center"/>
                                                        <Border Grid.Column="1" CornerRadius="8" Padding="7,1"
                                                                Background="#243a26">
                                                            <TextBlock Text="{Binding DurationDisplay}"
                                                                       Foreground="#7cc44a" FontSize="11"
                                                                       FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Note}" Foreground="#9ab088"
                                                               FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"
                                                               Visibility="{Binding Note, Converter={StaticResource NonEmptyVisConverter}}"/>
                                                    <ItemsControl ItemsSource="{Binding Markers}" Margin="0,3,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                                                    <TextBlock Text="&#128204;" Foreground="#d4a437"
                                                                               FontSize="11" Margin="0,0,6,0"/>
                                                                    <TextBlock Foreground="#7cc44a" FontFamily="Consolas"
                                                                               FontWeight="Bold" FontSize="11" Margin="0,0,8,0">
                                                                        <TextBlock.Text>
                                                                            <MultiBinding Converter="{StaticResource MarkerOffsetConverter}">
                                                                                <Binding Path="At"/>
                                                                                <Binding Path="DataContext.Start"
                                                                                         RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding TextOrClip}" Foreground="#d4a437"
                                                                               FontSize="11" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Grid Grid.Row="2" Margin="20,0,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="✎ Edit" Click="Edit_Click"
                        HorizontalAlignment="Left"
                        Foreground="#0a1410" Background="#4a7c3a" BorderThickness="0"
                        Padding="18,9" FontSize="13" FontWeight="Bold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    BorderBrush="#7cc44a" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#7cc44a"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="1" Content="Close" Click="Close_Click"
                        Foreground="#a0a0c0" Background="#1c2a1e" BorderThickness="0"
                        Padding="18,9" FontSize="13" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    BorderBrush="#2e4a30" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#243a26"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
