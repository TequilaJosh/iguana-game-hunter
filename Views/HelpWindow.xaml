<Window x:Class="GameTracker.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Help"
        Width="540" Height="640"
        MinWidth="440" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Icon="/iguana-eye.ico"
        Background="{StaticResource ScaleBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="Key" TargetType="Border">
            <Setter Property="Background" Value="#142016"/>
            <Setter Property="BorderBrush" Value="#4a7c3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="KeyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7cc44a"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="Desc" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#c4d4a8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7cc44a"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="ChangeBtn" TargetType="Button">
            <Setter Property="Background" Value="#1c2a1e"/>
            <Setter Property="Foreground" Value="#c4d4a8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#2e4a30" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#243a26"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#4a7c3a" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#0a1410"
                    BorderBrush="#2e4a30" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Image Source="/iguana-eye.ico" Width="16" Height="16" Margin="0,0,8,0"
                               VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="HELP &amp; SHORTCUTS" Foreground="#7cc44a"
                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="&#x2715;" Click="Close_Click"
                            Style="{StaticResource WindowCloseButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,16">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="KEYBOARD SHORTCUTS" Style="{StaticResource Section}"
                                   Margin="0" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Reset defaults" Click="Reset_Click"
                                Style="{StaticResource ChangeBtn}"/>
                    </Grid>
                    <TextBlock Text="Global — they work even while you're in your game. Click Change, then press your combo (include Ctrl, Alt, or Shift)."
                               Foreground="#7a9070" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="155"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Key}"
                                HorizontalAlignment="Left" Margin="0,4">
                            <TextBlock x:Name="ToggleChip" Style="{StaticResource KeyText}"/>
                        </Border>
                        <TextBlock Grid.Row="0" Grid.Column="1" Margin="12,4"
                                   Style="{StaticResource Desc}"
                                   Text="Start / stop a play session"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="Change" Click="ChangeToggle_Click"
                                Style="{StaticResource ChangeBtn}" Margin="8,4"/>

                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Key}"
                                HorizontalAlignment="Left" Margin="0,4">
                            <TextBlock x:Name="ClipChip" Style="{StaticResource KeyText}"/>
                        </Border>
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="12,4"
                                   Style="{StaticResource Desc}"
                                   Text="Mark a clip (instant, no label)"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="Change" Click="ChangeClip_Click"
                                Style="{StaticResource ChangeBtn}" Margin="8,4"/>

                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Key}"
                                HorizontalAlignment="Left" Margin="0,4">
                            <TextBlock x:Name="NoteChip" Style="{StaticResource KeyText}"/>
                        </Border>
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="12,4"
                                   Style="{StaticResource Desc}"
                                   Text="Quick note (a labeled clip)"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="Change" Click="ChangeNote_Click"
                                Style="{StaticResource ChangeBtn}" Margin="8,4"/>
                    </Grid>
                    <TextBlock x:Name="StatusText" Foreground="#d4a437" FontSize="12"
                               Margin="0,8,0,0" TextWrapping="Wrap"/>

                    <TextBlock Text="TIPS" Style="{StaticResource Section}"/>
                    <StackPanel>
                        <TextBlock Style="{StaticResource Desc}" Margin="0,3"
                                   Text="• Start on a card begins a timed session and moves it to Hunting."/>
                        <TextBlock Style="{StaticResource Desc}" Margin="0,3"
                                   Text="• The pop-out (⧉ on a Hunting card) shows the live timer, clip markers, a session goal, and notes — and can pin on top."/>
                        <TextBlock Style="{StaticResource Desc}" Margin="0,3"
                                   Text="• Clip markers record the time into your stream, so you can jump to them in the VOD."/>
                        <TextBlock Style="{StaticResource Desc}" Margin="0,3"
                                   Text="• Card buttons: ⏱ How Long To Beat, 📖 GameFAQs guide."/>
                        <TextBlock Style="{StaticResource Desc}" Margin="0,3"
                                   Text="• Right-click a card to move it, open its custom Wheel, or shed it."/>
                        <TextBlock Style="{StaticResource Desc}" Margin="0,3"
                                   Text="• Spin picks a random Dormant game; Recap copies a stream summary."/>
                        <TextBlock Style="{StaticResource Desc}" Margin="0,3"
                                   Text="• OBS (title bar) opens your stream overlay files for now-playing and wheel challenges."/>
                        <TextBlock Style="{StaticResource Desc}" Margin="0,3"
                                   Text="• Drag cards between columns, or right-click to move them."/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
