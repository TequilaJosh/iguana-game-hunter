<Window x:Class="GameTracker.Views.RecapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Stream Recap"
        Width="560" Height="640"
        MinWidth="420" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Icon="/iguana-eye.ico"
        Background="{StaticResource ScaleBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="RangeButton" TargetType="Button">
            <Setter Property="Background" Value="#1c2a1e"/>
            <Setter Property="Foreground" Value="#c4d4a8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#2e4a30" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#243a26"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#4a7c3a" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#0a1410"
                    BorderBrush="#2e4a30" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Image Source="/iguana-eye.ico" Width="16" Height="16" Margin="0,0,8,0"
                               VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="STREAM RECAP" Foreground="#7cc44a" FontSize="11"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="&#x2715;" Click="Close_Click"
                            Style="{StaticResource WindowCloseButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Toolbar -->
            <Border Grid.Row="1" Background="#0a1410" Padding="12,8"
                    BorderBrush="#2e4a30" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="TodayButton" Grid.Column="0" Content="Today"
                            Style="{StaticResource RangeButton}" Margin="0,0,6,0"
                            Click="Today_Click"/>
                    <Button x:Name="WeekButton" Grid.Column="1" Content="7 Days"
                            Style="{StaticResource RangeButton}" Margin="0,0,6,0"
                            Click="Week_Click"/>
                    <Button x:Name="AllButton" Grid.Column="2" Content="All Time"
                            Style="{StaticResource RangeButton}"
                            Click="All_Click"/>
                    <Button Grid.Column="4" Content="&#128203; Copy"
                            Style="{StaticResource RangeButton}" Click="Copy_Click"
                            Foreground="#0a1410" Background="#4a7c3a"/>
                </Grid>
            </Border>

            <TextBox x:Name="RecapText" Grid.Row="2"
                     IsReadOnly="True" TextWrapping="NoWrap"
                     Background="#0f1812" Foreground="#c4d4a8"
                     BorderThickness="0" Padding="14"
                     FontFamily="Consolas" FontSize="13"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"/>
        </Grid>
    </Border>
</Window>
