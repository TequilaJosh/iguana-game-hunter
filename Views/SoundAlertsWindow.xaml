<Window x:Class="GameTracker.Views.SoundAlertsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Sound Alerts"
        Width="540" Height="470"
        MinWidth="460" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Icon="/iguana-eye.ico"
        Background="{StaticResource ScaleBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Background" Value="#243a26"/>
            <Setter Property="Foreground" Value="#7cc44a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}" BorderBrush="#4a7c3a" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4a7c3a"/>
                                <Setter Property="Foreground" Value="#0a1410"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource SmallBtn}">
            <Setter Property="Background" Value="#4a7c3a"/>
            <Setter Property="Foreground" Value="#0a1410"/>
            <Setter Property="Padding" Value="18,5"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#142016"/>
            <Setter Property="Foreground" Value="#e8e0c4"/>
            <Setter Property="BorderBrush" Value="#2e4a30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#7cc44a"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#4a7c3a" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#0a1410" BorderBrush="#2e4a30" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Image Source="/iguana-eye.ico" Width="16" Height="16" Margin="0,0,8,0"
                               VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="SOUND ALERTS" Foreground="#7cc44a" FontSize="11"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="&#x2715;" Click="Cancel_Click"
                            Style="{StaticResource WindowCloseButton}" Height="32"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Hint -->
            <TextBlock Grid.Row="1" Margin="14,12,14,0" Foreground="#7a9070" FontSize="11" TextWrapping="Wrap"
                       Text="When a viewer types a command in chat (across any connected source), its sound plays. Commands usually start with ! — e.g. !airhorn"/>

            <!-- Rows -->
            <ScrollViewer Grid.Row="2" Margin="12,8,12,0" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="AlertList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputBox}" Margin="0,0,6,0"
                                         ToolTip="The chat command, e.g. !airhorn"/>
                                <TextBox Grid.Column="1" Text="{Binding FilePath}" IsReadOnly="True"
                                         Style="{StaticResource InputBox}" Margin="0,0,6,0"
                                         Foreground="#a8c488" ToolTip="{Binding FilePath}"/>
                                <Button Grid.Column="2" Content="Browse" Tag="{Binding}" Click="Browse_Click"
                                        Style="{StaticResource SmallBtn}"/>
                                <Button Grid.Column="3" Content="&#9654;" Tag="{Binding}" Click="Test_Click"
                                        Style="{StaticResource SmallBtn}" ToolTip="Test play"/>
                                <Button Grid.Column="4" Content="&#x2715;" Tag="{Binding}" Click="Remove_Click"
                                        Style="{StaticResource SmallBtn}" Margin="0" ToolTip="Remove"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Add -->
            <Button Grid.Row="3" Content="+ Add alert" Click="Add_Click" Style="{StaticResource SmallBtn}"
                    HorizontalAlignment="Left" Margin="12,10,0,0"/>

            <!-- Footer -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,12,12,14">
                <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource SmallBtn}"/>
                <Button Content="Save" Click="Save_Click" Style="{StaticResource ActionBtn}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
